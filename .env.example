# ── Spoiler Defendant — environment variable template ─────────────────────────
# Copy this file to .env.local for local development.
# Never commit .env.local or any file with real secrets.

# ── Form integrations (optional) ──────────────────────────────────────────────
# Formspree endpoint for email capture (https://formspree.io)
NEXT_PUBLIC_FORMSPREE_EMAIL_ID=

# Formspree endpoint for movie suggestions
NEXT_PUBLIC_FORMSPREE_SUGGEST_ID=

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Cloudflare Web Analytics token (no cookies, privacy-safe)
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ── Site metadata overrides ────────────────────────────────────────────────────
# These are pre-filled in src/config/site.ts — only override if needed per environment
# NEXT_PUBLIC_SITE_URL=https://spoilerdefendant.ngengwe.com
